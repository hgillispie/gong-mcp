# Gong API credentials
GONG_ACCESS_KEY=your_access_key_here
GONG_ACCESS_SECRET=your_access_secret_here

# OAuth Client Credentials for MCP clients (required when running in HTTP mode)
MCP_CLIENT_ID=your_client_id_here
MCP_CLIENT_SECRET=your_client_secret_here

# Public URL of the deployed server (used in OAuth discovery metadata)
SERVER_URL=https://your-app.railway.app